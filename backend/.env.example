# Copie para .env e preencha com seus valores (nunca commite o .env)

SECRET_KEY=troque-por-uma-chave-secreta-forte
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Login do dashboard (também cadastre usuários na tabela usuarios do Supabase)
DASHBOARD_EMAIL=admin@biopark.com.br
DASHBOARD_PASSWORD=defina-uma-senha-segura

# Supabase — Project Settings → API
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=sua-anon-key
SUPABASE_SERVICE_KEY=sua-service-role-key

# Assistente IA (opcional)
OPENAI_API_KEY=

# Alertas por e-mail (opcional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
